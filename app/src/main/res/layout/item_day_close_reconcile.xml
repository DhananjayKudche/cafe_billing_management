<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/gray_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/reconcileMaterialName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Material Name"
            android:textStyle="bold"
            android:textColor="@color/cafe_dark"
            android:textSize="18sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="System Stock"
                    android:textSize="12sp"
                    android:textColor="@color/cafe_medium"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/reconcileExpectedText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.50 KG"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/cafe_dark"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="@color/gray_light"
                android:layout_marginHorizontal="16dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:hint="Physical Stock"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                app:boxStrokeColor="@color/cafe_primary"
                app:hintTextColor="@color/cafe_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/reconcileActualInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/cafe_dark"
                    android:gravity="center"/>
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>