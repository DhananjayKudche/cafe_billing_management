<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@color/white">

    <TextView
        android:id="@+id/cartName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="3"
        android:text="Item Name"
        android:textColor="@color/cafe_dark"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.5"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnMinus"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_quantity_selector"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_remove"
            app:tint="@color/cafe_medium" />

        <TextView
            android:id="@+id/cartQty"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/cafe_dark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnPlus"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_quantity_selector"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_add"
            app:tint="@color/cafe_primary" />
    </LinearLayout>

    <TextView
        android:id="@+id/cartPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:gravity="center"
        android:text="₹10"
        android:textColor="@color/cafe_medium"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/cartAmount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.5"
        android:gravity="end"
        android:text="₹10"
        android:textColor="@color/cafe_accent"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>